# ============================================================
# StockWise AI Service — Environment Variables
# ============================================================

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stockwise

# --- Redis (for caching & message broker) ---
REDIS_URL=redis://localhost:6379/0

# --- Gemini AI (Google Generative AI) ---
GEMINI_API_KEY=your-gemini-api-key

# --- OpenAI (GPT-4o) ---
OPENAI_API_KEY=your-openai-api-key

# --- Other StockWise Services (if applicable) ---
DATA_PIPELINE_URL=http://localhost:8001
