# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=stockwise
POSTGRES_USER=stockwise
POSTGRES_PASSWORD=stockwise_dev_password

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_MANAGEMENT_PORT=15672

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
# REQUIRED: Generate a strong random secret (at least 32 bytes when UTF-8 encoded).
# Example: openssl rand -base64 48
# DO NOT use the placeholder below in production.
JWT_SECRET=your-256-bit-secret-change-in-production
JWT_ACCESS_TOKEN_EXPIRY_MS=900000
JWT_REFRESH_TOKEN_EXPIRY_MS=604800000

# AI APIs
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# Service URLs (internal Docker network)
USER_SERVICE_URL=http://user-service:8081
MARKET_SERVICE_URL=http://market-service:8082
PORTFOLIO_SERVICE_URL=http://portfolio-service:8083
AI_SERVICE_URL=http://ai-service:8000
DATA_PIPELINE_URL=http://data-pipeline:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:18080
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:18000

# Gateway Timeouts (ms)
GATEWAY_CONNECT_TIMEOUT_MS=5000
GATEWAY_READ_TIMEOUT_MS=10000
GATEWAY_WRITE_TIMEOUT_MS=10000

# CORS
# Comma-separated list of allowed origins for the API Gateway and User Service.
# Example for local dev: http://localhost:3000,http://localhost:13000
# Example for production: https://app.stockwise.com,https://www.stockwise.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:13000

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Embedding
EMBEDDING_DIMENSION=768

# Gmail SMTP (Forgot Password OTP)
# Set MAIL_USERNAME to your Gmail address
# Set MAIL_APP_PASSWORD to a Gmail App Password (NOT your Gmail account password)
# How to generate: Google Account → Security → 2-Step Verification → App Passwords
MAIL_USERNAME=your-email@gmail.com
MAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
